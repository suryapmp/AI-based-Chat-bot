# OpenRouter API Key for Deployed Version (Vite prefix required for Netlify/Vercel)
# IMPORTANT: Ensure this is set in your Netlify/Vercel Environment Variables as VITE_OPENROUTER_API_KEY
VITE_OPENROUTER_API_KEY=

# Gemini API Key (Optional for main widget)
GEMINI_API_KEY=

# SMTP Configuration for Email Notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
